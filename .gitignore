# Python
__pycache__/
*.pyc

# ── Private local data — NEVER commit/share these ──────────────────────────
# Your real account size, journal, watchlist, and approve/reject marks.
data/settings.json
data/trades.json
data/watchlist.json
data/suggestions.json
data/status.json
data/uploads/

# Per-user workspaces created on the server (one folder per friend).
data/users/

# Regenerable price cache (rebuilt from Yahoo; large).
data/cache/

# Coach-only generated markdown (regenerated from JSON locally).
watchlist.md
journal/trades.md

# Shared market snapshots are regenerated by the server's daily refresh — keep the
# repo slim and let the host rebuild them. (Comment these out if you prefer to ship
# a warm snapshot so friends see data the instant the server boots.)
data/market.json
data/sector_heat.json
data/news.json
data/suspicious.json

# NOTE: data/screeners.json, data/universe.json, data/themes.json, data/sectors.json
